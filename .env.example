# Spotify API credentials
SPOTIFY_CLIENT_ID=your-spotify-client-id
# Replace with the secret Spotify generated for your app
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# Example: SPOTIFY_CLIENT_SECRET=0e612f85f09b42cfba4f34bac653a1a1

# Default redirect URI served by this backend (adjust if hosting elsewhere)
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/spotify/callback

# Optional overrides
PORT=5000
# Comma-separated list of allowed origins for CORS (use * or leave blank for all)
CORS_ORIGIN=http://localhost:5000,http://localhost:3000
